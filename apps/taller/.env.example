# Taller — gestión de mantenimientos vía Telegram
# Copia a .env.local y rellena los valores.

# Telegram Bot (crear con @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Opcional: secreto al registrar el webhook (setWebhook secret_token)
TELEGRAM_WEBHOOK_SECRET=
# Chat ID del taller (obtener con @userinfobot o getUpdates). Filtra datos en presidencia.
TALLER_TELEGRAM_CHAT_ID=123456789
# Nombre mostrado en el panel de presidencia
TALLER_NOMBRE=Mi Taller

# OpenAI (extracción de datos con GPT-4o visión)
OPENAI_API_KEY=sk-...

# Supabase (solo servidor — webhook y dashboards)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# WhatsApp vía CallMeBot (https://www.callmebot.com)
CALLMEBOT_API_KEY=...

# URL pública de la app (para links al portal cliente en WhatsApp)
NEXT_PUBLIC_APP_URL=https://tu-dominio.vercel.app

# Opcional: PIN para proteger /presidencia
PRESIDENCIA_PIN=
