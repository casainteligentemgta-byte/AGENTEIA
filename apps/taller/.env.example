# Taller — gestión de mantenimientos vía Telegram
# Copia a .env.local y rellena los valores.

# Telegram Bot (crear con @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Opcional: secreto al registrar el webhook (setWebhook secret_token)
TELEGRAM_WEBHOOK_SECRET=

# OpenAI (extracción de datos con GPT-4o visión)
OPENAI_API_KEY=sk-...

# Supabase (solo servidor — webhook)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
