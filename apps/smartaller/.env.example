# SmartTaller — gestión de mantenimientos vía Telegram
# Copia a .env.local y rellena los valores.

# Telegram Bot (crear con @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_WEBHOOK_SECRET=mi-secreto-123

# OpenAI (extracción de datos con GPT-4o-mini visión)
OPENAI_API_KEY=sk-...

# Supabase — Auth (login/dashboard) + servidor (webhook)
# Copiar SIN viñetas ni espacios extra. Debe empezar por eyJ
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# WhatsApp — producción: Twilio (pendiente de integrar)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# WhatsApp pruebas: CallMeBot (solo envía al número que activó la key)
# https://www.callmebot.com/blog/free-api-whatsapp-messages/
CALLMEBOT_API_KEY=

# URL pública (links al portal cliente en WhatsApp)
NEXT_PUBLIC_APP_URL=https://smartaller.vercel.app

# Cron Vercel — recordatorios automáticos (generar string aleatorio)
CRON_SECRET=tu-secreto-cron-123

# Panel presidencia (recepción) — opcional; si no se define, el kiosk es público por URL
PRESIDENCIA_PIN=

# Email recordatorios — opcional vía Resend (https://resend.com)
# RESEND_API_KEY=re_...
# RESEND_FROM=SmartTaller <recordatorios@tudominio.com>
