# SmartTaller — gestión de mantenimientos vía Telegram
# Copia a .env.local y rellena los valores.

# Telegram Bot (crear con @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_WEBHOOK_SECRET=mi-secreto-123

# OpenAI (extracción de datos con GPT-4o-mini visión)
OPENAI_API_KEY=sk-...

# Supabase — Auth (login/dashboard) + servidor (webhook)
# Copiar SIN viñetas ni espacios extra. Debe empezar por eyJ
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# WhatsApp vía CallMeBot (https://www.callmebot.com)
CALLMEBOT_API_KEY=...
