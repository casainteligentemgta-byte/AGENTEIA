# Next.js (Tailwind, TypeScript, App Router) + Vercel AI SDK + Supabase
# Copia a .env.local y rellena los valores.

# Nombre del agente (título, cabecera y personalidad en el chat)
NEXT_PUBLIC_AGENT_NAME=Mi Agente

# OpenAI (chat + embeddings para memoria)
OPENAI_API_KEY=sk-...

# Búsqueda web — Serper recomendado (2500 búsquedas gratis en https://serper.dev)
SERPER_API_KEY=...
# Alternativa: TAVILY_API_KEY=tvly-...

# Supabase — Project Settings → API (mismo proyecto donde ejecutaste setup-completo.sql)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Auth: "true" exige login en /agente; "false" = acceso libre (demo)
NEXT_PUBLIC_REQUIRE_AUTH=false
